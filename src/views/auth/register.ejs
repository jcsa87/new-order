<%- include('../partials/header') %>

<div class="auth-container" style="max-width: 700px;"> <!-- Expanded for address info -->
    <div class="auth-header">
        <h2>Crear Cuenta</h2>
        <p>Únete a la experiencia New Order</p>
    </div>

    <form action="/auth/register" method="POST" class="auth-form">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <!-- Datos Personales -->
            <div class="form-section">
                <h3 style="margin-bottom: 1rem; color: var(--primary);">Datos Personales</h3>
                <div class="form-group">
                    <label for="nombre">Nombre</label>
                    <input type="text" id="nombre" name="nombre" placeholder="Juan" required>
                </div>
                <div class="form-group">
                    <label for="apellido">Apellido</label>
                    <input type="text" id="apellido" name="apellido" placeholder="Pérez" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="tu@email.com" required>
                </div>
                <div class="form-group">
                    <label for="contrasena">Contraseña</label>
                    <input type="password" id="contrasena" name="contrasena" placeholder="••••••••" required>
                </div>
                <div class="form-group">
                    <label for="id_rol">Tipo de Usuario</label>
                    <select id="id_rol" name="id_rol">
                        <% roles.forEach(role => { %>
                            <option value="<%= role.id_rol %>" <%= role.nombre === 'Cliente' ? 'selected' : '' %>><%= role.nombre %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <!-- Datos de Dirección -->
            <div class="form-section">
                <h3 style="margin-bottom: 1rem; color: var(--primary);">Dirección Obligatoria</h3>
                <div class="form-group">
                    <label for="calle">Calle</label>
                    <input type="text" id="calle" name="calle" placeholder="Av. Principal" required>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                    <div class="form-group">
                        <label for="numero_calle">Número</label>
                        <input type="text" id="numero_calle" name="numero_calle" placeholder="123" required>
                    </div>
                    <div class="form-group">
                        <label for="codigo_postal">C.P.</label>
                        <input type="text" id="codigo_postal" name="codigo_postal" placeholder="1000" required>
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                    <div class="form-group">
                        <label for="nro_piso">Piso</label>
                        <input type="text" id="nro_piso" name="nro_piso" placeholder="4">
                    </div>
                    <div class="form-group">
                        <label for="nro_departamento">Depto</label>
                        <input type="text" id="nro_departamento" name="nro_departamento" placeholder="B">
                    </div>
                </div>
                <div class="form-group">
                    <label for="id_provincia">Provincia</label>
                    <select id="id_provincia" name="id_provincia">
                        <% provincias.forEach(prov => { %>
                            <option value="<%= prov.id_provincia %>"><%= prov.nombre %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="id_localidad">Localidad</label>
                    <select id="id_localidad" name="id_localidad">
                        <% localidades.forEach(loc => { %>
                            <option value="<%= loc.id_localidad %>"><%= loc.nombre %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
        </div>

        <button type="submit" class="auth-btn" style="width: 100%;">Registrarse</button>
    </form>

    <div class="auth-footer">
        ¿Ya tienes cuenta? <a href="/auth/login">Inicia sesión</a>
    </div>
</div>

<%- include('../partials/footer') %>
