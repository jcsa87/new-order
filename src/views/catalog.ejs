<%- include('partials/header') %>

<section class="hero">
    <h1>Descubre lo último en tecnología</h1>
    <p>Calidad, garantía e innovación en cada pedido.</p>
</section>

<div class="product-grid">
    <% products.forEach(product => { %>
        <article class="product-card">
            <div class="product-image" style="background-image: url('<%= product.imagen %>'); background-size: cover;"></div>
            <div class="product-info">
                <h3><%= product.nombre %></h3>
                <p><%= product.descripcion %></p>
            </div>
            <div class="product-footer">
                <span class="price">$<%= product.precio_unitario %></span>
                <form action="/cart/add" method="POST">
                    <input type="hidden" name="productId" value="<%= product.id_producto %>">
                    <button type="submit" class="add-btn" <%= product.stock === 0 ? 'disabled' : '' %>>
                        <%= product.stock > 0 ? 'Añadir al carrito' : 'Sin Stock' %>
                    </button>
                </form>
            </div>
            <small style="color: var(--text-muted); margin-top: 10px;">En stock: <%= product.stock %></small>
        </article>
    <% }) %>
</div>

<%- include('partials/footer') %>
