<%- include('partials/header') %>

<section class="text-center mb-16 px-4">
    <h1 class="text-4xl md:text-6xl font-extrabold mb-4 tracking-tight text-gray-900 dark:text-white">
        Descubre lo último en <span class="text-primary">tecnología</span>
    </h1>
    <p class="text-lg text-gray-500 dark:text-slate-400 max-w-2xl mx-auto">
        Calidad, garantía e innovación en cada pedido. Explora nuestra selección premium.
    </p>
</section>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
    <% products.forEach(product => { %>
        <article class="group bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-primary/10 transition-all duration-300 flex flex-col">
            <!-- Product Image with Fallback -->
            <div class="relative h-56 overflow-hidden">
                <img 
                    src="<%= product.imagen || 'https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2070&auto=format&fit=crop' %>" 
                    alt="<%= product.nombre %>"
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                >
                <div class="absolute top-4 right-4">
                    <span class="bg-white/90 dark:bg-slate-800/90 backdrop-blur-sm text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-widest text-primary border border-primary/20">
                        Nuevo
                    </span>
                </div>
            </div>

            <!-- Product Info -->
            <div class="p-6 flex-grow flex flex-col">
                <h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                    <%= product.nombre %>
                </h3>
                <p class="text-sm text-gray-500 dark:text-slate-400 mb-6 line-clamp-2">
                    <%= product.descripcion %>
                </p>
                
                <div class="mt-auto flex items-center justify-between">
                    <div>
                        <span class="text-2xl font-black text-gray-900 dark:text-white">$<%= product.precio_unitario %></span>
                        <p class="text-[10px] text-gray-400 dark:text-slate-500 uppercase font-bold tracking-tighter">Stock: <%= product.stock %></p>
                    </div>

                    <form action="/cart/add" method="POST">
                        <input type="hidden" name="productId" value="<%= product.id_producto %>">
                        <button 
                            type="submit" 
                            class="p-3 rounded-2xl bg-primary text-white hover:bg-secondary active:scale-95 transition-all disabled:bg-gray-300 dark:disabled:bg-slate-800 disabled:cursor-not-allowed group/btn"
                            <%= product.stock === 0 ? 'disabled' : '' %>
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover/btn:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h1.5l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                        </button>
                    </form>
                </div>
            </div>
        </article>
    <% }) %>
</div>

<%- include('partials/footer') %>
