<%- include('partials/header') %>

<div class="max-w-2xl mx-auto text-center px-4 py-16">
    <!-- Success Icon Container -->
    <div class="inline-flex items-center justify-center w-24 h-24 bg-green-100 dark:bg-green-950/30 text-green-600 dark:text-green-400 rounded-full mb-8 shadow-xl shadow-green-500/10 animate-bounce">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    </div>

    <!-- Title -->
    <h2 class="text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-4">
        ¡Pedido Confirmado con Éxito!
    </h2>
    
    <!-- Subtitle -->
    <p class="text-lg text-gray-500 dark:text-sapphire-400 max-w-md mx-auto mb-8">
        Muchas gracias por tu compra. Tu pedido está siendo procesado y pronto estará en camino.
    </p>

    <!-- Order Info Card -->
    <div class="bg-white dark:bg-sapphire-900 border border-gray-150 dark:border-sapphire-800 rounded-3xl p-8 mb-10 shadow-sm max-w-md mx-auto relative overflow-hidden">
        <!-- Accent lines -->
        <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-green-400 to-emerald-500"></div>

        <div class="flex justify-between items-center mb-4">
            <span class="text-xs uppercase font-bold text-gray-400 tracking-wider">Identificador de Pedido</span>
            <span class="text-xs font-bold px-3 py-1 bg-green-100 dark:bg-green-950/50 text-green-700 dark:text-green-400 rounded-full">Procesado</span>
        </div>
        <p class="text-3xl font-black text-gray-900 dark:text-white select-all">#<%= id_pedido %></p>
        
        <div class="mt-6 pt-6 border-t border-gray-100 dark:border-sapphire-800 flex justify-between items-center text-xs text-gray-400">
            <span>Fecha</span>
            <span class="font-semibold text-gray-700 dark:text-sapphire-200" id="currentDateText"></span>
        </div>
    </div>

    <!-- Navigation Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/" class="w-full sm:w-auto px-8 py-4 bg-primary text-white font-black rounded-2xl hover:bg-secondary active:scale-95 transition-all shadow-lg shadow-primary/20 text-center">
            Seguir Comprando
        </a>
        <a href="/faq" class="w-full sm:w-auto px-8 py-4 bg-gray-200 dark:bg-sapphire-800 text-gray-700 dark:text-sapphire-200 font-bold rounded-2xl hover:bg-gray-300 dark:hover:bg-sapphire-750 transition-all text-center">
            Preguntas Frecuentes
        </a>
    </div>
</div>

<script>
    // Set current date in localized format
    document.addEventListener('DOMContentLoaded', () => {
        const dateElement = document.getElementById('currentDateText');
        if (dateElement) {
            const now = new Date();
            const options = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
            dateElement.textContent = now.toLocaleDateString('es-ES', options);
        }
    });
</script>

<%- include('partials/footer') %>
