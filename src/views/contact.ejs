<%- include('partials/header') %>

<div class="max-w-4xl mx-auto py-20 px-6">
    <div class="text-center mb-16">
        <h1 class="text-4xl font-black text-gray-900 dark:text-white mb-4 tracking-tight">Contáctanos</h1>
        <p class="text-gray-500 dark:text-sapphire-400">Estamos aquí para ayudarte. Envíanos un mensaje.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- Info column -->
        <div class="space-y-8">
            <div class="bg-primary/5 dark:bg-sapphire-800/10 p-8 rounded-3xl border border-primary/10 dark:border-sapphire-700/20">
                <h3 class="text-lg font-bold text-primary mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    Email
                </h3>
                <p class="text-gray-600 dark:text-sapphire-400 text-sm font-medium">hola@neworder.com.ar</p>
            </div>

            <div class="bg-primary/5 dark:bg-sapphire-800/10 p-8 rounded-3xl border border-primary/10 dark:border-sapphire-700/20">
                <h3 class="text-lg font-bold text-primary mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Ubicación
                </h3>
                <p class="text-gray-600 dark:text-sapphire-400 text-sm font-medium">Av. Corrientes 1234, CABA</p>
            </div>
        </div>

        <!-- Form column -->
        <div class="md:col-span-2 bg-white dark:bg-sapphire-900 p-10 rounded-3xl border border-gray-100 dark:border-sapphire-800 shadow-xl">
            <form action="#" method="POST" class="space-y-6">
                <div>
                    <label class="text-xs font-black text-gray-400 dark:text-sapphire-500 uppercase tracking-widest block mb-2 pl-1">Nombre Completo</label>
                    <input type="text" class="w-full px-5 py-4 bg-gray-50 dark:bg-sapphire-800/50 border border-gray-200 dark:border-sapphire-700 rounded-2xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all">
                </div>
                <div>
                    <label class="text-xs font-black text-gray-400 dark:text-sapphire-500 uppercase tracking-widest block mb-2 pl-1">Email</label>
                    <input type="email" class="w-full px-5 py-4 bg-gray-50 dark:bg-sapphire-800/50 border border-gray-200 dark:border-sapphire-700 rounded-2xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all">
                </div>
                <div>
                    <label class="text-xs font-black text-gray-400 dark:text-sapphire-500 uppercase tracking-widest block mb-2 pl-1">Mensaje</label>
                    <textarea rows="4" class="w-full px-5 py-4 bg-gray-50 dark:bg-sapphire-800/50 border border-gray-200 dark:border-sapphire-700 rounded-2xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all resize-none"></textarea>
                </div>
                <button type="button" class="w-full py-4 bg-primary text-white font-black rounded-2xl shadow-lg shadow-primary/20 hover:opacity-90 active:scale-[0.99] transition-all">Enviar Mensaje</button>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
