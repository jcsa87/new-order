<%- include('partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white">Tu Carrito</h2>
        <a href="/" class="text-sm font-semibold text-primary hover:text-secondary flex items-center transition-colors">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Seguir comprando
        </a>
    </div>
    
    <% if (items.length === 0) { %>
        <div class="text-center py-20 bg-white dark:bg-slate-900 rounded-3xl border border-dashed border-gray-300 dark:border-slate-700">
            <svg class="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            <p class="text-xl font-medium text-gray-500 dark:text-slate-400">El carrito está vacío.</p>
            <a href="/" class="mt-6 inline-block bg-primary text-white px-8 py-3 rounded-xl font-bold hover:bg-secondary transition-all">Explorar productos</a>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            <!-- Lista de Productos -->
            <div class="lg:col-span-2 space-y-4">
                <% items.forEach(item => { %>
                    <div class="flex items-center p-4 bg-white dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm">
                        <div class="w-20 h-20 bg-gray-100 dark:bg-slate-800 rounded-xl overflow-hidden flex-shrink-0">
                            <!-- Placeholder small if needed, but keeping it simple for now -->
                            <div class="w-full h-full bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
                                <svg class="w-8 h-8 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                            </div>
                        </div>
                        <div class="ml-4 flex-grow">
                            <h4 class="font-bold text-gray-900 dark:text-white leading-tight"><%= item.nombre %></h4>
                            <p class="text-sm text-gray-400 dark:text-slate-500 mt-1">Cantidad: <span class="font-bold text-gray-600 dark:text-slate-300"><%= item.quantity %></span></p>
                        </div>
                        <div class="text-right">
                            <span class="block font-black text-gray-900 dark:text-white text-lg">$<%= (item.precio_unitario * item.quantity).toFixed(2) %></span>
                            <span class="text-[10px] text-gray-400 dark:text-slate-600 uppercase font-bold tracking-wider">$<%= item.precio_unitario %> c/u</span>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Resumen de Compra -->
            <div class="lg:col-span-1">
                <div class="bg-gray-900 dark:bg-slate-900 p-8 rounded-3xl text-white shadow-2xl shadow-gray-900/20">
                    <h3 class="text-xl font-bold mb-6 border-b border-white/10 pb-4">Resumen</h3>
                    
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-gray-400 italic">
                            <span>Subtotal</span>
                            <span class="text-white not-italic">$<%= totals.subtotal %></span>
                        </div>
                        <div class="flex justify-between text-gray-400">
                            <span>IVA (21%)</span>
                            <span class="text-white font-medium">$<%= totals.taxes %></span>
                        </div>
                        <div class="pt-4 border-t border-white/10 flex justify-between items-end">
                            <span class="text-sm uppercase tracking-widest font-bold text-primary">Total</span>
                            <span class="text-3xl font-black text-white">$<%= totals.total %></span>
                        </div>
                    </div>
                    
                    <button class="w-full py-4 bg-primary rounded-2xl font-black text-lg hover:bg-secondary active:scale-95 transition-all shadow-lg shadow-primary/20">
                        Finalizar Compra
                    </button>
                    
                    <p class="text-[10px] text-center mt-4 text-gray-500 uppercase tracking-widest leading-relaxed">
                        Pago seguro garantizado <br> por New Order System
                    </p>
                </div>
            </div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
