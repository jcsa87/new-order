<%- include('partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white">Tu Carrito</h2>
        <a href="/" class="text-sm font-semibold text-primary hover:text-secondary flex items-center transition-colors">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Seguir comprando
        </a>
    </div>
    
    <% if (itemsCarrito.length === 0) { %>
        <div class="text-center py-20 bg-white dark:bg-sapphire-900 rounded-3xl border border-dashed border-gray-300 dark:border-sapphire-700">
            <svg class="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-sapphire-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            <p class="text-xl font-medium text-gray-500 dark:text-sapphire-400">El carrito está vacío.</p>
            <a href="/" class="mt-6 inline-block bg-primary text-white px-8 py-3 rounded-xl font-bold hover:bg-secondary transition-all">Explorar productos</a>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            <!-- Lista de Productos -->
            <div class="lg:col-span-2 space-y-4">
                <% itemsCarrito.forEach(item => { %>
                    <div class="flex items-center p-4 bg-white dark:bg-sapphire-900 rounded-2xl border border-gray-100 dark:border-sapphire-800 shadow-sm relative group">
                        <div class="w-20 h-20 bg-gray-100 dark:bg-sapphire-800 rounded-xl overflow-hidden flex-shrink-0">
                            <img src="<%= item.imagen %>" alt="<%= item.nombre %>" class="w-full h-full object-cover">
                        </div>
                        <div class="ml-4 flex-grow min-w-0">
                            <h4 class="font-bold text-gray-900 dark:text-white leading-tight truncate"><%= item.nombre %></h4>
                            <p class="text-xs text-gray-400 dark:text-sapphire-500 mt-1">$<%= item.precio_unitario %> c/u</p>
                            
                            <!-- Controles de Cantidad -->
                            <div class="flex items-center mt-3 space-x-3">
                                <div class="flex items-center bg-gray-50 dark:bg-sapphire-800 rounded-lg border border-gray-100 dark:border-sapphire-700">
                                    <form action="/cart/actualizar" method="POST">
                                        <input type="hidden" name="productId" value="<%= item.id_producto %>">
                                        <input type="hidden" name="delta" value="-1">
                                        <button type="submit" class="p-1.5 hover:text-primary transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
                                        </button>
                                    </form>
                                    <span class="px-3 text-sm font-bold text-gray-700 dark:text-sapphire-200"><%= item.quantity %></span>
                                    <form action="/cart/actualizar" method="POST">
                                        <input type="hidden" name="productId" value="<%= item.id_producto %>">
                                        <input type="hidden" name="delta" value="1">
                                        <button type="submit" 
                                            class="p-1.5 hover:text-primary transition-colors disabled:opacity-20 disabled:cursor-not-allowed"
                                            <%= item.quantity >= item.stock ? 'disabled' : '' %>
                                        >
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col items-end space-y-4">
                            <form action="/cart/quitar" method="POST">
                                <input type="hidden" name="productId" value="<%= item.id_producto %>">
                                <button type="submit" class="text-gray-300 hover:text-red-500 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </form>
                            <span class="font-black text-gray-900 dark:text-white text-lg">$<%= (item.precio_unitario * item.quantity).toFixed(2) %></span>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Resumen de Compra -->
            <div class="lg:col-span-1">
                <div class="bg-gray-900 dark:bg-sapphire-900 p-8 rounded-3xl text-white shadow-2xl shadow-gray-900/20">
                    <h3 class="text-xl font-bold mb-6 border-b border-white/10 pb-4">Resumen</h3>
                    
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-gray-400 italic">
                            <span>Subtotal</span>
                            <span class="text-white not-italic">$<%= totales.subtotal %></span>
                        </div>
                        <div class="flex justify-between text-gray-400">
                            <span>Impuestos (IVA 21%)</span>
                            <span class="text-white font-medium">$<%= totales.impuestos %></span>
                        </div>
                        <div class="pt-4 border-t border-white/10 flex justify-between items-end">
                            <span class="text-sm uppercase tracking-widest font-bold text-primary">Total Final</span>
                            <span class="text-3xl font-black text-white">$<%= totales.total %></span>
                        </div>
                    </div>
                    
                    <button class="w-full py-4 bg-primary rounded-2xl font-black text-lg hover:bg-secondary active:scale-95 transition-all shadow-lg shadow-primary/20">
                        Finalizar Compra
                    </button>
                    
                    <p class="text-[10px] text-center mt-4 text-gray-500 uppercase tracking-widest leading-relaxed">
                        Pago seguro garantizado <br> por New Order System
                    </p>
                </div>
            </div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
