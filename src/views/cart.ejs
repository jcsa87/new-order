<%- include('partials/header') %>

<div class="cart-container">
    <h2>Tu Carrito</h2>
    <br>
    
    <% if (items.length === 0) { %>
        <p style="text-align: center; color: var(--text-muted);">El carrito está vacío.</p>
        <br>
        <a href="/" style="color: var(--primary); text-decoration: none; display: block; text-align: center;">Volver al catálogo</a>
    <% } else { %>
        <div class="cart-items">
            <% items.forEach(item => { %>
                <div class="cart-item">
                    <div>
                        <h4><%= item.name %></h4>
                        <small>Cantidad: <%= item.quantity %></small>
                    </div>
                    <span class="price">$<%= (item.price * item.quantity).toFixed(2) %></span>
                </div>
            <% }) %>
        </div>

        <div class="cart-summary">
            <p>Subtotal: <span>$<%= totals.subtotal %></span></p>
            <p>IVA (21%): <span>$<%= totals.taxes %></span></p>
            <div class="total-row">Total: $<%= totals.total %></div>
            
            <button class="checkout-btn">Proceder al pago (Sprint 2)</button>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
