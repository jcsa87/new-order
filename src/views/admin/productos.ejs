<%- include('../partials/header_admin') %>

<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Gestión de Productos</h1>
        
        <div class="flex gap-4 items-center">
            <!-- Formulario de filtro por categoría -->
            <form action="/admin/productos" method="GET" class="flex items-center gap-2">
                <label class="text-gray-700 dark:text-gray-300 font-bold text-sm">Filtrar:</label>
                <select name="categoria" onchange="this.form.submit()" class="rounded-xl border-gray-300 dark:border-sapphire-700 bg-white dark:bg-sapphire-800 p-2 text-gray-900 dark:text-white text-sm">
                    <option value="">Todas las Categorías</option>
                    <% categorias.forEach(cat => { %>
                        <option value="<%= cat.id_categoria %>" <%= categoriaActual == cat.id_categoria ? 'selected' : '' %>>
                            <%= cat.nombre %>
                        </option>
                    <% }) %>
                </select>
            </form>

            <a href="/admin/productos/nuevo" class="bg-primary text-white px-4 py-2 rounded-xl hover:bg-secondary transition-colors font-bold">+ Nuevo Producto</a>
        </div>
    </div>

    <!-- [CASO DE USO: Gestionar Productos - Visualizar listado] -->
    <div class="bg-white dark:bg-sapphire-900 rounded-2xl shadow overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-100 dark:bg-sapphire-800 text-gray-700 dark:text-gray-300">
                    <th class="p-4 border-b dark:border-sapphire-700">ID</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Imagen</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Nombre</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Categoría</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Precio</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Stock</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Estado</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% productos.forEach(producto => { %>
                <tr class="border-b dark:border-sapphire-800 hover:bg-gray-50 dark:hover:bg-sapphire-800/50">
                    <td class="p-4 font-bold text-gray-900 dark:text-white">#<%= producto.id_producto %></td>
                    <td class="p-4">
                        <img src="<%= producto.imagen || 'https://via.placeholder.com/50' %>" alt="Img" class="w-12 h-12 rounded object-cover">
                    </td>
                    <td class="p-4 text-gray-700 dark:text-gray-300"><%= producto.nombre %></td>
                    <td class="p-4 text-gray-700 dark:text-gray-300"><%= producto.categoria_nombre || 'Sin categoría' %></td>
                    <td class="p-4 font-bold text-green-600 dark:text-green-400">$<%= producto.precio_unitario %></td>
                    <td class="p-4 text-gray-700 dark:text-gray-300"><%= producto.stock %></td>
                    <td class="p-4">
                        <% if(producto.estado_producto === 'activo') { %>
                            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Activo</span>
                        <% } else { %>
                            <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded">Inactivo</span>
                        <% } %>
                    </td>
                    <td class="p-4 flex gap-2">
                        <!-- [CASO DE USO: Gestionar Productos - Modificar Datos] -->
                        <a href="/admin/productos/editar/<%= producto.id_producto %>" class="bg-blue-500 text-white px-3 py-1 rounded text-sm hover:bg-blue-600">Editar</a>
                        
                        <!-- [CASO DE USO: Gestionar Productos - Desactivar] -->
                        <% if(producto.estado_producto === 'activo') { %>
                        <form action="/admin/productos/desactivar/<%= producto.id_producto %>" method="POST" onsubmit="return confirm('¿Seguro que deseas desactivar este producto para que ya no se venda?');">
                            <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded text-sm hover:bg-red-600">Desactivar</button>
                        </form>
                        <% } else { %>
                        <!-- Botón para volver a Activar -->
                        <form action="/admin/productos/activar/<%= producto.id_producto %>" method="POST" onsubmit="return confirm('¿Volver a habilitar la venta de este producto?');">
                            <button type="submit" class="bg-green-500 text-white px-3 py-1 rounded text-sm hover:bg-green-600">Activar</button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
