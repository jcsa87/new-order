<%- include('../partials/header_admin') %>

<div class="container mx-auto px-4 py-8 max-w-2xl">
    <div class="mb-6">
        <a href="/admin/productos" class="text-primary hover:underline">&larr; Volver a Productos</a>
    </div>

    <div class="bg-white dark:bg-sapphire-900 rounded-2xl shadow p-8 border border-gray-200 dark:border-sapphire-800">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6"><%= title %></h1>

        <!-- [CASO DE USO: Gestionar Productos - Registrar/Modificar Datos] -->
        <form action="<%= producto ? '/admin/productos/editar/' + producto.id_producto : '/admin/productos/nuevo' %>" method="POST" enctype="multipart/form-data" class="space-y-4">
            
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nombre del Producto</label>
                <input type="text" name="nombre" value="<%= producto ? producto.nombre : '' %>" required class="w-full rounded-xl border-gray-300 dark:border-sapphire-700 bg-gray-50 dark:bg-sapphire-800 p-3 text-gray-900 dark:text-white">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Descripción</label>
                <textarea name="descripcion" required class="w-full rounded-xl border-gray-300 dark:border-sapphire-700 bg-gray-50 dark:bg-sapphire-800 p-3 text-gray-900 dark:text-white"><%= producto ? producto.descripcion : '' %></textarea>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Precio Unitario ($)</label>
                    <input type="number" step="0.01" name="precio_unitario" value="<%= producto ? producto.precio_unitario : '' %>" required class="w-full rounded-xl border-gray-300 dark:border-sapphire-700 bg-gray-50 dark:bg-sapphire-800 p-3 text-gray-900 dark:text-white">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Stock Inicial</label>
                    <input type="number" name="stock" value="<%= producto ? producto.stock : '0' %>" required class="w-full rounded-xl border-gray-300 dark:border-sapphire-700 bg-gray-50 dark:bg-sapphire-800 p-3 text-gray-900 dark:text-white">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Categoría</label>
                <select name="id_categoria" required class="w-full rounded-xl border-gray-300 dark:border-sapphire-700 bg-gray-50 dark:bg-sapphire-800 p-3 text-gray-900 dark:text-white">
                    <option value="">Selecciona una categoría...</option>
                    <% categorias.forEach(cat => { %>
                        <option value="<%= cat.id_categoria %>" <%= producto && producto.id_categoria === cat.id_categoria ? 'selected' : '' %>>
                            <%= cat.nombre %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Imagen del Producto (Archivo local)</label>
                <input type="file" name="imagen" accept="image/*" class="w-full rounded-xl border-gray-300 dark:border-sapphire-700 bg-gray-50 dark:bg-sapphire-800 p-3 text-gray-900 dark:text-white">
                <% if(producto && producto.imagen) { %>
                    <p class="text-xs text-gray-500 mt-1">Imagen actual guardada. Sube una nueva solo si deseas reemplazarla.</p>
                <% } %>
            </div>

            <div class="pt-4">
                <button type="submit" class="w-full bg-primary text-white font-bold py-3 rounded-xl hover:bg-secondary transition-colors">
                    <%= producto ? 'Guardar Cambios' : 'Registrar Producto' %>
                </button>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
