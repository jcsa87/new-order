<%- include('../partials/header_admin') %>

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Gestión de Usuarios</h1>

    <!-- [CASO DE USO: Gestionar Usuarios - Visualizar listado] -->
    <div class="bg-white dark:bg-sapphire-900 rounded-2xl shadow overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-100 dark:bg-sapphire-800 text-gray-700 dark:text-gray-300">
                    <th class="p-4 border-b dark:border-sapphire-700">ID</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Nombre</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Email</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Rol</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Estado</th>
                    <th class="p-4 border-b dark:border-sapphire-700">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% usuarios.forEach(usuario => { %>
                <tr class="border-b dark:border-sapphire-800 hover:bg-gray-50 dark:hover:bg-sapphire-800/50">
                    <td class="p-4 font-bold text-gray-900 dark:text-white">#<%= usuario.id_usuario %></td>
                    <td class="p-4 text-gray-700 dark:text-gray-300"><%= usuario.nombre %> <%= usuario.apellido %></td>
                    <td class="p-4 text-gray-700 dark:text-gray-300"><%= usuario.email %></td>
                    <td class="p-4 text-gray-700 dark:text-gray-300">
                        <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded"><%= usuario.rol_nombre %></span>
                    </td>
                    <td class="p-4">
                        <% if(usuario.estado === 'activo' || !usuario.estado) { %>
                            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Activo</span>
                        <% } else { %>
                            <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded">Inactivo / Baneado</span>
                        <% } %>
                    </td>
                    <td class="p-4">
                        <!-- [CASO DE USO: Gestionar Usuarios - Desactivar Usuario] -->
                        <!-- [CASO DE USO: Gestionar Usuarios - Desactivar Usuario] -->
                        <% if(usuario.id_rol === 1) { %>
                            <span class="text-gray-400 text-sm font-semibold italic">Protegido (Admin)</span>
                        <% } else if(usuario.estado !== 'inactivo') { %>
                        <form action="/admin/usuarios/desactivar/<%= usuario.id_usuario %>" method="POST" onsubmit="return confirm('¿Seguro que deseas desactivar este usuario?');">
                            <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded text-sm hover:bg-red-600">Desactivar</button>
                        </form>
                        <% } else { %>
                        <form action="/admin/usuarios/activar/<%= usuario.id_usuario %>" method="POST" onsubmit="return confirm('¿Seguro que deseas reactivar este usuario?');">
                            <button type="submit" class="bg-green-500 text-white px-3 py-1 rounded text-sm hover:bg-green-600">Activar</button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
