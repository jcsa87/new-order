<%- include('../partials/header_admin') %>

<div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8 text-center">Panel de Administración</h1>

    <!-- [CASO DE USO: Gestionar todo el sistema] -->
    <!-- Mostrar accesos rápidos a todos los submódulos de administración -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- Tarjeta: Gestionar Productos -->
        <a href="/admin/productos" class="block p-6 bg-white dark:bg-sapphire-900 rounded-2xl shadow hover:shadow-lg transition-shadow border border-gray-200 dark:border-sapphire-800">
            <h2 class="text-2xl font-bold text-primary mb-2">🛍️ Productos</h2>
            <p class="text-gray-500 dark:text-sapphire-400">Crear, modificar o desactivar los productos del catálogo.</p>
        </a>

        <!-- Tarjeta: Gestionar Categorías -->
        <a href="/admin/categorias" class="block p-6 bg-white dark:bg-sapphire-900 rounded-2xl shadow hover:shadow-lg transition-shadow border border-gray-200 dark:border-sapphire-800">
            <h2 class="text-2xl font-bold text-primary mb-2">📁 Categorías</h2>
            <p class="text-gray-500 dark:text-sapphire-400">Añadir nuevas categorías o desactivar las existentes.</p>
        </a>

        <!-- Tarjeta: Gestionar Pedidos -->
        <a href="/admin/pedidos" class="block p-6 bg-white dark:bg-sapphire-900 rounded-2xl shadow hover:shadow-lg transition-shadow border border-gray-200 dark:border-sapphire-800">
            <h2 class="text-2xl font-bold text-primary mb-2">📦 Pedidos</h2>
            <p class="text-gray-500 dark:text-sapphire-400">Ver pedidos pendientes y actualizar estados de envío.</p>
        </a>

        <!-- Tarjeta: Gestionar Usuarios -->
        <a href="/admin/usuarios" class="block p-6 bg-white dark:bg-sapphire-900 rounded-2xl shadow hover:shadow-lg transition-shadow border border-gray-200 dark:border-sapphire-800">
            <h2 class="text-2xl font-bold text-primary mb-2">👥 Usuarios</h2>
            <p class="text-gray-500 dark:text-sapphire-400">Ver listado de clientes y desactivar cuentas (baneos).</p>
        </a>

        <!-- Tarjeta: Reporte de Ventas -->
        <a href="/admin/reportes" class="block p-6 bg-white dark:bg-sapphire-900 rounded-2xl shadow hover:shadow-lg transition-shadow border border-gray-200 dark:border-sapphire-800">
            <h2 class="text-2xl font-bold text-primary mb-2">📊 Reporte Ventas</h2>
            <p class="text-gray-500 dark:text-sapphire-400">Ver ingresos totales según el estado de los pedidos.</p>
        </a>
    </div>
</div>

<%- include('../partials/footer') %>
