<%- include('partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb & Header -->
    <div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <a href="/pedidos" class="text-sm text-gray-500 dark:text-sapphire-400 hover:text-primary dark:hover:text-primary transition-colors flex items-center mb-2">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Volver a Mis Pedidos
            </a>
            <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight flex items-center gap-3">
                Pedido #<%= pedido.id_pedido %>
                <% if (pedido.estado === 'Pendiente') { %>
                    <span class="px-3 py-1 text-sm font-semibold rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-400">
                        <%= pedido.estado %>
                    </span>
                <% } else if (pedido.estado === 'Enviado' || pedido.estado === 'Completado') { %>
                    <span class="px-3 py-1 text-sm font-semibold rounded-full bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-400">
                        <%= pedido.estado %>
                    </span>
                <% } else { %>
                    <span class="px-3 py-1 text-sm font-semibold rounded-full bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                        <%= pedido.estado %>
                    </span>
                <% } %>
            </h2>
            <p class="text-sm text-gray-500 dark:text-sapphire-300 mt-1">
                Realizado el <%= new Date(pedido.fecha_creacion).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Column: Products -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white dark:bg-sapphire-900 rounded-3xl shadow-sm border border-gray-150 dark:border-sapphire-800 overflow-hidden">
                <div class="p-6 border-b border-gray-150 dark:border-sapphire-800">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Artículos</h3>
                </div>
                <div class="divide-y divide-gray-150 dark:divide-sapphire-800">
                    <% detalles.forEach(item => { %>
                        <div class="p-6 flex flex-col sm:flex-row gap-6 items-center sm:items-start">
                            <div class="w-24 h-24 shrink-0 rounded-2xl bg-gray-100 dark:bg-sapphire-950 flex items-center justify-center overflow-hidden border border-gray-200 dark:border-sapphire-800/50">
                                <% if (item.producto_imagen) { %>
                                    <img src="<%= item.producto_imagen %>" alt="<%= item.producto_nombre %>" class="w-full h-full object-cover">
                                <% } else { %>
                                    <svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                <% } %>
                            </div>
                            <div class="flex-1 text-center sm:text-left">
                                <h4 class="text-lg font-bold text-gray-900 dark:text-white"><%= item.producto_nombre %></h4>
                                <% if(item.producto_descripcion) { %>
                                    <p class="text-sm text-gray-500 dark:text-sapphire-300 mt-1 line-clamp-1"><%= item.producto_descripcion %></p>
                                <% } %>
                                <div class="mt-4 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
                                    <div class="text-sm text-gray-600 dark:text-sapphire-200 font-medium bg-gray-100 dark:bg-sapphire-800 px-3 py-1 rounded-lg inline-block w-fit">
                                        Cant: <%= item.cantidad %> × $<%= parseFloat(item.precio_unitario).toFixed(2) %>
                                    </div>
                                    <div class="text-lg font-black text-gray-900 dark:text-white">
                                        $<%= parseFloat(item.subtotal_item).toFixed(2) %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Sidebar: Summary & Details -->
        <div class="space-y-6">
            <!-- Order Summary -->
            <div class="bg-white dark:bg-sapphire-900 rounded-3xl shadow-sm border border-gray-150 dark:border-sapphire-800 p-6 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary"></div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Resumen</h3>
                
                <div class="space-y-4 text-sm">
                    <div class="flex justify-between text-gray-600 dark:text-sapphire-300 font-medium">
                        <span>Subtotal de productos</span>
                        <span>$<%= parseFloat(pedido.subtotal_pedido || 0).toFixed(2) %></span>
                    </div>
                    <% if (pedido.descuento_aplicado > 0) { %>
                    <div class="flex justify-between text-green-600 dark:text-green-400 font-medium">
                        <span>Descuento</span>
                        <span>-$<%= parseFloat(pedido.descuento_aplicado || 0).toFixed(2) %></span>
                    </div>
                    <% } %>
                    <!-- Nota: El envío e impuestos están sumados en el total en este diseño simple.
                         Si guardáramos el costo de envío separado en la BD, lo mostraríamos aquí. -->
                    <div class="pt-4 border-t border-gray-150 dark:border-sapphire-800 flex justify-between items-center">
                        <span class="text-lg font-bold text-gray-900 dark:text-white">Total Final</span>
                        <span class="text-2xl font-black text-gray-900 dark:text-white">$<%= parseFloat(pedido.total || 0).toFixed(2) %></span>
                    </div>
                </div>
            </div>

            <!-- Shipping & Payment Info -->
            <div class="bg-white dark:bg-sapphire-900 rounded-3xl shadow-sm border border-gray-150 dark:border-sapphire-800 p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Información</h3>
                
                <div class="space-y-6">
                    <!-- Shipping Address -->
                    <div>
                        <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400 dark:text-sapphire-400 mb-2">Dirección de Entrega</h4>
                        <div class="flex items-start gap-3">
                            <div class="p-2 bg-gray-100 dark:bg-sapphire-800 rounded-xl text-gray-600 dark:text-sapphire-300 shrink-0">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <p class="text-sm text-gray-700 dark:text-sapphire-200 font-medium leading-relaxed">
                                <%= direccionCompleta %>
                            </p>
                        </div>
                    </div>

                    <!-- Shipping Method -->
                    <div>
                        <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400 dark:text-sapphire-400 mb-2">Método de Envío</h4>
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-gray-100 dark:bg-sapphire-800 rounded-xl text-gray-600 dark:text-sapphire-300 shrink-0">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
                            </div>
                            <p class="text-sm text-gray-700 dark:text-sapphire-200 font-medium">
                                <%= metodoEnvio ? metodoEnvio.nombre : 'No especificado' %>
                            </p>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div>
                        <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400 dark:text-sapphire-400 mb-2">Método de Pago</h4>
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-gray-100 dark:bg-sapphire-800 rounded-xl text-gray-600 dark:text-sapphire-300 shrink-0">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                            </div>
                            <p class="text-sm text-gray-700 dark:text-sapphire-200 font-medium">
                                <%= metodoPago ? metodoPago.nombre : 'No especificado' %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
