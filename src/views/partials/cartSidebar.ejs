<!-- src/views/partials/cartSidebar.ejs -->
<div id="cartSidebar" class="fixed inset-0 z-[60] invisible transition-all duration-300">
    <!-- Overlay -->
    <div id="cartOverlay" class="absolute inset-0 bg-sapphire-950/40 backdrop-blur-sm opacity-0 transition-opacity duration-300" onclick="closeCart()"></div>
    
    <!-- Sidebar -->
    <div id="cartPanel" class="absolute top-0 right-0 h-full w-full max-w-md bg-white dark:bg-sapphire-900 shadow-2xl translate-x-full transition-transform duration-300 flex flex-col">
        <!-- Header -->
        <div class="p-6 border-b border-gray-100 dark:border-sapphire-800 flex items-center justify-between">
            <h2 class="text-xl font-extrabold text-gray-900 dark:text-white flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h1.5l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                Tu Carrito
            </h2>
            <button onclick="closeCart()" class="p-2 rounded-xl border border-gray-100 dark:border-sapphire-800 hover:bg-gray-50 dark:hover:bg-sapphire-800 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <div class="flex-grow overflow-y-auto p-6 space-y-4">
            <% if (errorMessage) { %>
                <div id="sidebarErrorAlert" class="p-3 bg-red-100 text-red-600 rounded-xl text-xs font-bold mb-4 animate-bounce flex items-center justify-between transition-opacity duration-500">
                    <span><%= errorMessage %></span>
                    <button onclick="this.parentElement.remove()" class="ml-2 hover:text-red-800 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                    <script>
                        setTimeout(() => {
                            const alert = document.getElementById('sidebarErrorAlert');
                            if (alert) alert.style.opacity = '0';
                            setTimeout(() => alert && alert.remove(), 500);
                        }, 5000);
                    </script>
                </div>
            <% } %>

            <% if (typeof itemsCarrito === 'undefined' || itemsCarrito.length === 0) { %>
                <div class="h-full flex flex-col items-center justify-center text-center space-y-4 opacity-50">
                    <svg class="w-16 h-16 text-gray-300 dark:text-sapphire-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                    <p class="text-gray-500 dark:text-sapphire-400 font-medium">El carrito está vacío</p>
                    <button onclick="closeCart()" class="text-primary font-bold text-sm">Explorar productos</button>
                </div>
            <% } else { %>
                <% itemsCarrito.forEach(item => { %>
                    <div class="flex items-center gap-4 p-4 bg-gray-50 dark:bg-sapphire-800/30 rounded-2xl border border-gray-100 dark:border-sapphire-800 relative group">
                        <div class="w-16 h-16 bg-white dark:bg-sapphire-800 rounded-xl overflow-hidden flex-shrink-0">
                            <img src="<%= item.imagen %>" alt="<%= item.nombre %>" class="w-full h-full object-cover">
                        </div>
                        <div class="flex-grow min-w-0">
                            <h4 class="font-bold text-gray-900 dark:text-white truncate text-xs"><%= item.nombre %></h4>
                            <div class="flex items-center mt-2 space-x-2">
                                <form action="/cart/actualizar" method="POST" class="flex items-center border border-gray-200 dark:border-sapphire-700 rounded-md bg-white dark:bg-sapphire-800 overflow-hidden">
                                    <input type="hidden" name="productId" value="<%= item.id_producto %>">
                                    <button type="button" onclick="this.form.nuevaCantidad.value--; this.form.submit()" class="px-2 py-0.5 hover:bg-gray-100 dark:hover:bg-sapphire-700 transition-colors text-xs">-</button>
                                    <input type="number" name="nuevaCantidad" value="<%= item.quantity %>" 
                                        class="w-8 text-center text-[10px] font-bold bg-transparent focus:outline-none dark:text-sapphire-200"
                                        onchange="this.form.submit()" min="0">
                                    <button type="button" onclick="this.form.nuevaCantidad.value++; this.form.submit()" <%= item.quantity >= item.stock ? 'disabled' : '' %> 
                                        class="px-2 py-0.5 hover:bg-gray-100 dark:hover:bg-sapphire-700 transition-colors text-xs disabled:opacity-30">+</button>
                                </form>
                                <span class="text-[10px] text-gray-400 dark:text-sapphire-500 font-bold">$<%= item.precio_unitario %></span>
                            </div>
                        </div>
                        <div class="flex flex-col items-end gap-2">
                             <form action="/cart/quitar" method="POST">
                                <input type="hidden" name="productId" value="<%= item.id_producto %>">
                                <button type="submit" class="text-gray-300 hover:text-red-500 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </form>
                            <span class="font-black text-gray-900 dark:text-white text-sm">$<%= Number(item.subtotal_item).toFixed(2) %></span>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <!-- Footer / Summary -->
        <% if (typeof itemsCarrito !== 'undefined' && itemsCarrito.length > 0) { %>
            <div class="p-6 bg-gray-50 dark:bg-sapphire-800/80 border-t border-gray-100 dark:border-sapphire-800">
                <div class="space-y-3 mb-6">
                    <div class="flex justify-between text-xs text-gray-500 dark:text-sapphire-400">
                        <span>Subtotal (Neto)</span>
                        <span class="font-bold text-gray-900 dark:text-white">$<%= totales.subtotal %></span>
                    </div>
                    <div class="flex justify-between text-xs text-gray-500 dark:text-sapphire-400">
                        <span>Impuestos (IVA 21%)</span>
                        <span class="font-bold text-gray-900 dark:text-white">$<%= totales.impuestos %></span>
                    </div>
                    <div class="flex justify-between text-xs text-gray-500 dark:text-green-500">
                        <span>Envío</span>
                        <span class="font-bold">GRATIS</span>
                    </div>
                    <div class="pt-3 border-t border-gray-200 dark:border-sapphire-700 flex justify-between items-end">
                        <span class="text-xs uppercase font-black text-primary tracking-widest">Total Final</span>
                        <span class="text-2xl font-black text-gray-900 dark:text-white">$<%= totales.total %></span>
                    </div>
                </div>
                <button class="w-full py-4 bg-primary text-white rounded-2xl font-black text-lg hover:bg-secondary active:scale-95 transition-all shadow-lg shadow-primary/20">
                    Finalizar Compra
                </button>
            </div>
        <% } %>
    </div>
</div>

<script>
    function openCart() {
        const sidebar = document.getElementById('cartSidebar');
        const panel = document.getElementById('cartPanel');
        const overlay = document.getElementById('cartOverlay');
        
        sidebar.classList.remove('invisible');
        setTimeout(() => {
            panel.classList.remove('translate-x-full');
            overlay.classList.replace('opacity-0', 'opacity-100');
        }, 10);
    }

    function closeCart() {
        const sidebar = document.getElementById('cartSidebar');
        const panel = document.getElementById('cartPanel');
        const overlay = document.getElementById('cartOverlay');
        
        panel.classList.add('translate-x-full');
        overlay.classList.replace('opacity-100', 'opacity-0');
        
        setTimeout(() => {
            sidebar.classList.add('invisible');
        }, 300);
    }

    // Auto-open if redirected with flag
    <% if (locals.abrirCarrito) { %>
        window.addEventListener('DOMContentLoaded', openCart);
    <% } %>
</script>
