<!-- src/views/partials/header.ejs -->
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Order</title>
    <link rel="icon" type="image/svg+xml" href="/brand/logo_main.svg">
    <!-- Tailwind Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        sapphire: {
                            50: '#eceff8',
                            100: '#dadff1',
                            200: '#b5bfe3',
                            300: '#8fa0d6',
                            400: '#6a80c8',
                            500: '#4560ba',
                            600: '#374d95',
                            700: '#293a70',
                            800: '#1c264a',
                            900: '#0e1325',
                            950: '#0a0d1a'
                        },
                        primary: '#4560ba',
                        secondary: '#374d95',
                        accent: '#6a80c8',
                    }
                }
            }
        }
    </script>
    <script>
        // Theme Toggle Script
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark')
        } else {
            document.documentElement.classList.remove('dark')
        }

        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.theme = 'light';
            } else {
                document.documentElement.classList.add('dark');
                localStorage.theme = 'dark';
            }
        }
    </script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        nav {
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Hide HTML5 Number Input Spinners */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { 
            -webkit-appearance: none; 
            margin: 0; 
        }

        input[type=number] {
            -moz-appearance: textfield;
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 dark:bg-sapphire-950 dark:text-slate-100 transition-colors duration-300">
    <nav id="navbar"
        class="sticky top-0 z-50 bg-white/80 dark:bg-sapphire-900/80 backdrop-blur-md border-b border-gray-200 dark:border-sapphire-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16 relative">
                <!-- Left: User Greeting -->
                <div class="flex items-center w-1/3">
                    <% if (user) { %>
                        <div class="hidden sm:flex items-center space-x-3">
                            <span class="text-sm font-medium text-gray-400 dark:text-sapphire-400">Hola, <span
                                    class="text-gray-900 dark:text-white font-semibold">
                                    <%= user.name %>
                                </span></span>
                            <a href="/auth/logout"
                                class="text-[10px] uppercase tracking-wider font-bold text-gray-400 hover:text-accent transition-colors">Salir</a>
                        </div>
                        <% } %>
                </div>

                <!-- Center: Logo -->
                <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center">
                    <a href="/"
                        class="flex items-center hover:scale-105 transition-transform">
                        <img src="/brand/logo_black.svg" class="h-10 dark:hidden" alt="New Order">
                        <img src="/brand/logo_white.svg" class="h-10 hidden dark:block" alt="New Order">
                    </a>
                </div>

                <!-- Right: Actions -->
                <div class="flex items-center justify-end space-x-2 sm:space-x-4 w-1/3">
                    <!-- Theme Toggle -->
                    <button onclick="toggleTheme()"
                        class="p-2 rounded-lg bg-gray-100 dark:bg-slate-800 hover:ring-2 hover:ring-primary/50 transition-all">
                        <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z">
                        </svg>
                        <svg class="w-5 h-5 hidden dark:block text-yellow-500" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 3v1m0 16v1m9-9h-1M4 9h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z">
                        </svg>
                    </button>

                    <button onclick="openCart()"
                        class="relative p-2 text-gray-600 dark:text-slate-300 hover:text-primary transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="8" cy="21" r="1" />
                            <circle cx="19" cy="21" r="1" />
                            <path
                                d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12" />
                        </svg>
                        <% if (typeof cantidadCarrito !=='undefined' && cantidadCarrito > 0) { %>
                            <span
                                class="absolute top-0 right-0 bg-accent text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full ring-2 ring-white dark:ring-slate-900">
                                <%= cantidadCarrito %>
                            </span>
                            <% } %>
                    </button>

                    <% if (!user) { %>
                        <a href="/auth/login"
                            class="text-xs font-bold text-white bg-primary px-4 py-2 rounded-lg hover:opacity-90 transition-all shadow-md shadow-primary/20">Iniciar Sesión</a>
                        <% } %>
                </div>
            </div>
        </div>
    </nav>

    <script>
        // Navbar Scroll Behavior
        let lastScrollY = window.scrollY;
        const nav = document.getElementById('navbar');

        window.addEventListener('scroll', () => {
            if (window.scrollY > lastScrollY && window.scrollY > 100) {
                nav.classList.add('-translate-y-full');
            } else {
                nav.classList.remove('-translate-y-full');
            }
            lastScrollY = window.scrollY;
        });
    </script>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 min-h-screen">