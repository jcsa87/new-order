<!-- src/views/partials/header.ejs -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Order | Catálogo Premium</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body>
    <nav>
        <div class="nav-left">
            <a href="/" class="logo">NEW ORDER</a>
        </div>
        <div class="nav-right">
            <a href="/cart" class="cart-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                    <span class="cart-count"><%= cartCount %></span>
                <% } %>
            </a>
            
            <% if (user) { %>
                <div class="user-menu">
                    <span class="user-name">Hola, <%= user.name %>!</span>
                    <a href="/auth/logout" class="nav-link">Cerrar Sesión</a>
                </div>
            <% } else { %>
                <a href="/auth/login" class="nav-link">Iniciar Sesión</a>
                <a href="/auth/register" class="nav-link register-btn">Registrarse</a>
            <% } %>
        </div>
    </nav>
    <main>
