<%- include('partials/header') %>

<div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="flex mb-8 text-sm font-medium text-gray-400" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="/products" class="hover:text-primary transition-colors">Productos</a>
            </li>
            <li>
                <div class="flex items-center">
                    <svg class="w-3 h-3 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none"
                        viewBox="0 0 6 10">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="m1 9 4-4-4-4" />
                    </svg>
                    <span class="ml-1 md:ml-2 text-gray-500 dark:text-gray-400">
                        <%= producto.nombre %>
                    </span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Left Column: Image -->
        <div class="space-y-6">
            <div class="aspect-square overflow-hidden rounded-[2.5rem] bg-white dark:bg-sapphire-900 shadow-2xl border border-gray-100 dark:border-sapphire-800 transition-all duration-500 group">
                <img src="<%= producto.imagen || 'https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2070&auto=format&fit=crop' %>"
                    alt="<%= producto.nombre %>"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
            </div>
            
            <!-- Technical Info Cards -->
            <div class="grid grid-cols-3 gap-4">
                <div class="bg-white dark:bg-sapphire-900 p-4 rounded-2xl border border-gray-100 dark:border-sapphire-800 text-center">
                    <svg class="w-6 h-6 mx-auto mb-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <span class="text-[10px] font-bold uppercase text-gray-400 block">Rendimiento</span>
                    <span class="text-xs font-bold dark:text-white">Premium</span>
                </div>
                <div class="bg-white dark:bg-sapphire-900 p-4 rounded-2xl border border-gray-100 dark:border-sapphire-800 text-center">
                    <svg class="w-6 h-6 mx-auto mb-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.046A11.955 11.955 0 013 12c0 5.391 3.551 10.106 8.542 11.666l.458.143.458-.143C17.449 22.106 21 17.391 21 12a11.955 11.955 0 01-0.382-3.016z"/></svg>
                    <span class="text-[10px] font-bold uppercase text-gray-400 block">Garantía</span>
                    <span class="text-xs font-bold dark:text-white">12 Meses</span>
                </div>
                <div class="bg-white dark:bg-sapphire-900 p-4 rounded-2xl border border-gray-100 dark:border-sapphire-800 text-center">
                    <svg class="w-6 h-6 mx-auto mb-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    <span class="text-[10px] font-bold uppercase text-gray-400 block">Envío</span>
                    <span class="text-xs font-bold dark:text-white">Gratis</span>
                </div>
            </div>
        </div>

        <!-- Right Column: Info -->
        <div class="flex flex-col">
            <div class="mb-4">
                <span class="bg-primary/10 text-primary text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest">
                    <%= producto.stock > 0 ? 'En Stock' : 'Sin Stock' %>
                </span>
            </div>
            
            <h1 class="text-4xl md:text-6xl font-black text-gray-900 dark:text-white mb-6 tracking-tight leading-tight">
                <%= producto.nombre %>
            </h1>

            <p class="text-xl text-gray-500 dark:text-sapphire-400 mb-10 leading-relaxed font-medium">
                <%= producto.descripcion %>
            </p>

            <div class="bg-gray-50 dark:bg-sapphire-800/50 rounded-3xl p-8 mb-10 border border-gray-100 dark:border-sapphire-800">
                <div class="flex items-end gap-4 mb-8">
                    <span class="text-5xl font-black text-gray-900 dark:text-white">$<%= producto.precio_unitario %></span>
                    <span class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">Precio Final</span>
                </div>

                <div class="flex items-center gap-4 mb-6">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full <%= producto.stock > 0 ? 'bg-green-500 animate-pulse' : 'bg-red-500' %>"></div>
                        <span class="text-sm font-bold <%= producto.stock > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %> uppercase tracking-widest">
                            <%= producto.stock > 0 ? 'Stock Disponible' : 'Agotado' %>
                        </span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <form action="/cart/agregar" method="POST" class="space-y-4">
                    <input type="hidden" name="productId" value="<%= producto.id_producto %>">

                    <div class="flex items-center gap-4">
                        <div class="flex items-center bg-white dark:bg-sapphire-900 rounded-2xl border border-gray-100 dark:border-sapphire-700 p-2 shadow-sm">
                            <label for="cantidad" class="sr-only">Cantidad</label>
                            <input type="number" id="cantidad" name="cantidad" value="1" min="1"
                                max="<%= producto.stock %>"
                                class="w-16 bg-transparent text-center font-black text-xl focus:outline-none dark:text-white">
                        </div>

                        <button type="submit"
                            class="flex-grow flex items-center justify-center gap-3 bg-primary hover:bg-secondary text-white font-black py-5 px-8 rounded-2xl shadow-xl shadow-primary/20 transition-all duration-300 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:active:scale-100"
                            <%=producto.stock===0 ? 'disabled' : '' %>>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                            </svg>
                            Agregar al Carrito
                        </button>
                    </div>
                </form>
            </div>

            <!-- Features List -->
            <div class="space-y-6">
                <h3 class="text-lg font-black text-gray-900 dark:text-white uppercase tracking-widest border-b border-gray-100 dark:border-sapphire-800 pb-4">Características Destacadas</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex items-start gap-4">
                        <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-gray-900 dark:text-white">Calidad Certificada</h4>
                            <p class="text-xs text-gray-500 dark:text-sapphire-400 mt-1">Producto verificado bajo estándares internacionales.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-gray-900 dark:text-white">Soporte 24/7</h4>
                            <p class="text-xs text-gray-500 dark:text-sapphire-400 mt-1">Atención especializada para todas tus consultas.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>